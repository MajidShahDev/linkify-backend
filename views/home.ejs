<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Linkify</title>
    <link rel="stylesheet" href="/css/output.css">
    <!-- npx @tailwindcss/cli -i ./public/css/input.css -o ./public/css/output.css --watch -->
</head>

<body class="font-sans bg-gray-100 m-0 p-0">

    <div class="container max-w-4xl mx-auto bg-white p-6 rounded-lg shadow-lg my-10">

        <header class="flex justify-between items-center mb-6">
            <a href="/" class="no-underline">
                <h1 class="text-gray-800 text-2xl m-0">Linkify</h1>
            </a>
            <form action="/user/logout" method="get">
                <button type="submit"
                    class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded text-sm cursor-pointer">Logout</button>
            </form>
        </header>

        <% if (locals.id) { %>
            <div class="generated bg-blue-100 border-l-4 border-blue-500 p-3 mb-4">
                URL Generated:
                <a href="<%= baseUrl %>/<%= id %>" target="_blank" class="text-blue-600 underline">
                    <%= baseUrl %>/<%= id %>
                </a>
            </div>
            <% } %>

                <form method="post" action="/url" class="mb-5">
                    <label class="block">
                        Paste Your Long URL Here
                        <input type="text" name="url" placeholder="https://example.com/long-url"
                            value="<%= oldInput ? oldInput.url : '' %>"
                            class="w-full mt-2 p-2 border border-gray-300 rounded outline-gray-400 hover:border-gray-400"
                            required>
                    </label>

                    <% if (errors && errors.length> 0) { %>
                        <ul class="text-red-600 mt-2">
                            <% errors.forEach(msg=> { %>
                                <li>
                                    <%= msg %>
                                </li>
                                <% }) %>
                        </ul>
                        <% } %>
                            <div class="flex justify-between items-end mt-4">

                                <button type="submit"
                                    class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded cursor-pointer">
                                    Generate Short Link
                                </button>

                                <div class="flex gap-2">

                                    <div class="relative inline-block w-55">
                                        <select id="expiryOption" onchange="handleExpiryChange(this.value)"
                                            class="p-2 pr-8 border border-gray-300 rounded hover:border-gray-400 outline-gray-400 appearance-none w-full">

                                            <option value="">Expiry (Never)</option>
                                            <option value="1">1 day</option>
                                            <option value="7">7 days</option>
                                            <option value="30">30 days</option>
                                            <option value="custom">Custom</option>
                                        </select>

                                        <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center">
                                            <svg class="w-3.5 h-3.5 text-gray-800" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </div>
                                    </div>

                                    <input type="date" id="expiresAt" name="expiresAt" value="<%= oldInput ? oldInput.expiresAt : '' %>"
                                        class="w-55 p-2 border border-gray-300 hover:border-gray-400 rounded outline-gray-400 hidden" />

                                </div>
                            </div>
                </form>

                <hr class="border-t border-gray-300 my-4">
                <form method="get" action="/" class="mb-4 flex gap-2">

                    <input type="text" name="search" placeholder="Search URLs..." value="<%= search || '' %>"
                        class="w-full mt-2 p-2 border border-gray-300 hover:border-gray-400 rounded outline-gray-400" />

                    <div class="relative inline-block w-45">
                        <select name="sort"
                            class="mt-2 p-2 pr-8 border border-gray-300 rounded hover:border-gray-400 outline-gray-400 appearance-none w-full">
                            <option value="newest" <%=sort==="newest" ? "selected" : "" %>>Newest</option>
                            <option value="oldest" <%=sort==="oldest" ? "selected" : "" %>>Oldest</option>
                            <option value="mostClicks" <%=sort==="mostClicks" ? "selected" : "" %>>Most Clicks</option>
                            <option value="leastClicks" <%=sort==="leastClicks" ? "selected" : "" %>>Least Clicks
                            </option>
                        </select>

                        <div
                            class="pointer-events-none absolute inset-y-0 right-2 top-3 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5  text-gray-800" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 9l-7 7-7-7" />
                            </svg>
                        </div>
                    </div>


                    <button class="mt-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded cursor-pointer">
                        Search
                    </button>

                </form>


                <% if (locals.urls) { %>
                    <table class="w-full table-fixed border-collapse mt-5 text-sm ">
                        <thead class="rounded-lg">
                            <tr class="bg-gray-100 border border-gray-200 ">
                                <th class="w-12 px-3 py-4 text-left align-top font-semibold tracking-wide">S.No</th>
                                <th class="w-6  py-4 text-left align-top pl-15 font-semibold tracking-wide"></th>
                                <th class="w-63 px-3 py-4 text-left align-top font-semibold tracking-wide">Short
                                    Link</th>
                                <th class="w-6 px-3 py-4 align-top font-semibold tracking-wide"></th>
                                <th
                                    class="max-w-112.5 px-3 py-4 text-left align-top wrap-break-word pl-3 font-semibold tracking-wide">
                                    Redirect
                                    URL
                                </th>
                                <th class="w-20 px-3 py-4 text-center align-top font-semibold tracking-wide">Clicks</th>
                                <th class="w-16 px-3 py-4 text-left align-top font-semibold tracking-wide">Action</th>
                                <th class="w-29 px-4 py-4 text-left align-top font-semibold tracking-wide">Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% urls.forEach((url, index)=> { %>
                                <tr class="border-b border-gray-300">
                                    <td class="px-3 py-4  align-top">
                                        <!-- <%= index + 1 %> -->
                                        <%= (currentPage - 1) * 15 + index + 1 %>

                                    </td>
                                    <td class="px-3 py-4 flex items-start gap-1 align-top ">
                                        <img src="/images/qr-code.svg" onclick="openQr('<%= url.shortId %>')"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100 active:opacity-30"
                                            alt="QR Code" title="QR Code" />
                                        <img src="/images/copy.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100 active:opacity-30"
                                            data-url="<%= baseUrl %>/<%= url.shortId %>" alt="Copy URL" title="Copy" />
                                    </td>
                                    <td class="px-3 py-4 items-start align-top ">
                                        <a href="<%= baseUrl %>/<%= url.shortId %>" target="_blank"
                                            class="text-blue-600 no-underline wrap-break-word ">
                                            <%= baseUrl %>/<%= url.shortId %>
                                        </a>
                                    </td>
                                    <td class="px-3 py-4 text-gray-400 rotate-45 relative bottom-3.5">↝</td>
                                    <td class="px-3 py-4  break-all whitespace-normal align-top max-w-112.5">


                                        <div>
                                            <span class="redirectText line-clamp-2 break-all">
                                                <%= url.redirectURL %>
                                            </span>

                                            <button class="seeMore text-blue-600 text-xs ml-px hidden hover:underline">
                                                see more
                                            </button>
                                        </div>

                                    </td>
                                    <td class="px-3 py-4  align-top ">
                                        <a class="text-blue-600 hover:underline flex gap-1 text-center justify-center"
                                            target="_blank" href="<%= baseUrl %>/url/analytics/<%= url.shortId %>">
                                            <%= url.visitHistory.length %>
                                                <img src="/images/analytics.svg"
                                                    class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100"
                                                    alt="Analytics" title="Analytics" />
                                        </a>
                                    </td>
                                    <td class="px-3 py-4 align-top flex gap-2">
                                        <img src="/images/edit.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100"
                                            alt="Edit URL" title="Edit"
                                            onclick="openEditModal('<%= url.shortId %>', '<%= url.redirectURL %>')" />
                                        <img src="/images/trash.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100"
                                            alt="Delete URL" title="Delete"
                                            onclick="openDeleteModal('<%= url.shortId %>')" />
                                    </td>
                                    <td class="px-4 py-4  align-top text-gray-500">
                                        <!-- <%= url.createdAt ? new Date(url.createdAt).toLocaleString('en-US', {
                                            year: 'numeric' , month: 'numeric' , day: 'numeric' ,  }) : '-' %> -->
                                        <%= url.createdAt ? new Date(url.createdAt).toLocaleDateString('en-GB', {
                                            day: '2-digit' , month: 'short' , year: 'numeric' , hour: 'numeric' ,
                                            minute: 'numeric' , hour12: true }) : '-' %>
                                    </td>


                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>

                        <div class="flex justify-center mt-6 gap-2">

                            <% if(currentPage> 1) { %>
                                <a href="/?page=<%= currentPage - 1 %>&search=<%= search %>&sort=<%= sort %>"
                                    class="px-3 py-1 border rounded border-gray-900">
                                    Prev
                                </a>
                                <% } %>

                                    <% for(let i=1; i <=totalPages; i++) { %>
                                        <a href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>" class="px-3 py-1 border border-gray-900 rounded
       <%= currentPage === i ? 'bg-gray-800 text-white ' : '' %>">
                                            <%= i %>
                                        </a>
                                        <% } %>

                                            <% if(currentPage < totalPages) { %>
                                                <a href="/?page=<%= currentPage + 1 %>&search=<%= search %>&sort=<%= sort %>"
                                                    class="px-3 py-1 border border-gray-900 rounded ">
                                                    Next
                                                </a>
                                                <% } %>

                        </div>


                        <!-- Edit Modal -->
                        <div id="editModal"
                            class="fixed inset-0 bg-opacity-40 flex items-center justify-center hidden z-50">
                            <div class="bg-white p-6 rounded-lg w-80 text-center border border-gray-500 shadow-lg">
                                <h3 class="text-lg font-semibold mb-2">Edit URL</h3>
                                <p class="mb-3">Update the original URL:</p>
                                <input type="text" id="editUrlInput"
                                    class="w-full border border-gray-300 rounded p-2 mb-4"
                                    placeholder="Enter new URL" />

                                <div class="flex justify-between">
                                    <button id="cancelEdit"
                                        class="px-4 py-2 border rounded cursor-pointer hover:bg-gray-200 active:bg-gray-300">Cancel</button>
                                    <button id="confirmEdit"
                                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded cursor-pointer">Save</button>
                                </div>
                            </div>
                        </div>

                        <!-- Delete Modal -->
                        <div id="deleteModal"
                            class="fixed inset-0 bg-opacity-40 flex items-center justify-center hidden z-50">
                            <div class="bg-white p-6 rounded-lg w-80 text-center border border-gray-500 shadow-lg">
                                <h3 class="text-lg font-semibold mb-2">Delete URL</h3>
                                <p class="mb-3">Are you sure you want to delete this URL?</p>

                                <div class="flex justify-between">
                                    <button id="cancelDelete"
                                        class="px-4 py-2 border rounded cursor-pointer  hover:bg-gray-200 active:bg-gray-300 ">Cancel</button>
                                    <button id="confirmDelete"
                                        class="px-4 py-2 bg-red-500 hover:bg-red-600 active:bg-red-700 text-white rounded cursor-pointer">Delete</button>
                                </div>
                            </div>
                        </div>

                        <!-- QR Modal -->
                        <div id="qrModal"
                            class="fixed inset-0 bg-opacity-40 flex items-center justify-center hidden z-50">
                            <div class="bg-white p-12 rounded-lg text-center border shadow-lg  border-gray-500">
                                <h3 class="text-lg font-semibold mb-3">QR Code</h3>

                                <img id="qrImage" class="mx-auto mb-4" />

                                <button onclick="closeQrModal()"
                                    class="px-4 py-2 border rounded hover:bg-gray-200 active:bg-gray-300">
                                    Close
                                </button>
                            </div>
                        </div>


    </div>

    <script>

        // Edit Function
        let editTargetId = null;

        function openEditModal(shortId, currentUrl) {
            editTargetId = shortId;
            document.getElementById("editUrlInput").value = currentUrl;
            document.getElementById("editModal").classList.remove("hidden");
        }

        function closeEditModal() {
            editTargetId = null;
            document.getElementById("editModal").classList.add("hidden");
        }

        document.getElementById("cancelEdit").onclick = closeEditModal;

        document.getElementById("confirmEdit").onclick = async function () {
            if (!editTargetId) return;

            const newUrl = document.getElementById("editUrlInput").value.trim();
            if (!newUrl) {
                alert("URL cannot be empty");
                return;
            }

            const res = await fetch(`/url/${editTargetId}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ newUrl }),
            });

            if (res.ok) {
                closeEditModal();
                location.reload();
            } else {
                const data = await res.json();
                alert(data.error || "Failed to update");
            }
        };

        // Delete Function
        let deleteTargetId = null;

        function openDeleteModal(shortId) {
            deleteTargetId = shortId;
            document.getElementById("deleteModal").classList.remove("hidden");
        }

        function closeDeleteModal() {
            deleteTargetId = null;
            document.getElementById("deleteModal").classList.add("hidden");
        }

        document.getElementById("cancelDelete").onclick = closeDeleteModal;

        document.getElementById("confirmDelete").onclick = async function () {
            if (!deleteTargetId) return;

            const res = await fetch(`/url/${deleteTargetId}`, {
                method: "DELETE",
            });

            if (res.ok) {
                closeDeleteModal();
                location.reload();
            } else {
                const data = await res.json();
                alert(data.error || "Failed to delete");
            }
        };

        // Copy Icon Function
        document.querySelectorAll(".copyIcon").forEach(icon => {
            icon.addEventListener("click", () => {
                const url = icon.dataset.url;

                navigator.clipboard.writeText(url)
                    .then(() => { })
                    .catch(err => {
                        console.error("Failed to copy: ", err);
                        alert("Failed to copy URL");
                    });
            });
        });

        // Redirect Text Function
        document.querySelectorAll(".redirectText").forEach(text => {
            const btn = text.nextElementSibling;

            if (text.scrollHeight > text.clientHeight) {
                btn.classList.remove("hidden");
            }

            btn.addEventListener("click", () => {
                text.classList.toggle("line-clamp-2");
                btn.innerText = btn.innerText === "see more" ? "see less" : "see more";
            });
        });

        // QR Code Function
        function openQr(shortId) {
            fetch(`url/qr/${shortId}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById("qrImage").src = data.qr;
                    document.getElementById("qrModal").classList.remove("hidden");
                });
        }

        function closeQrModal() {
            document.getElementById("qrModal").classList.add("hidden");
        }


        function handleExpiryChange(value) {
            const input = document.getElementById("expiresAt");

            if (value === "custom") {
                input.classList.remove("hidden");
                input.value = "";
                return;
            }

            if (!value) {
                input.classList.add("hidden");
                input.value = "";
                return;
            }

            const days = parseInt(value);

            const now = new Date();
            now.setDate(now.getDate() + days);

            // ✅ LOCAL date fix
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, "0");
            const day = String(now.getDate()).padStart(2, "0");

            const local = `${year}-${month}-${day}`;

            input.value = local;
            input.classList.remove("hidden");
        }



    </script>

</body>

</html>