<!-- Template Engine 
     A template engine is a software component that allows developers
     to embed programming logic (like loops, conditions, and variables)
     into HTML templates, and then render dynamic HTML pages by combining 
     these templates with data.
     
     Example Template Engine (like EJS)
     Combines HTML templates + data to generate static HTML on the server.
     Example: < %= user.name % >  → replaced with actual data, sent as final HTML.
     Mostly server-side rendering. -->

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Linkify</title>

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            background: #fff;
            padding: 25px;
            border-radius: 8px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        h1 {
            margin: 0;
            color: #333;
        }

        button {
            padding: 8px 16px;
            border: none;
            background-color: #007bff;
            color: white;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }

        button:hover {
            background-color: #0056b3;
        }

        form {
            margin-bottom: 20px;
        }

        input[type="text"] {
            width: 100%;
            padding: 10px;
            margin-top: 6px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .generated {
            margin: 15px 0;
            padding: 10px;
            background-color: #e9f5ff;
            border-left: 4px solid #007bff;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        table th,
        table td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
            text-align: left;
            font-size: 14px;
        }

        table th {
            background-color: #f1f1f1;
        }

        table tr:hover {
            background-color: #f9f9f9;
        }

        a {
            color: #007bff;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .logout-btn {
            background-color: #dc3545;
        }

        .logout-btn:hover {
            background-color: #b52a37;
        }

        .modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .hidden {
            display: none;
        }

        .modal-box {
            background: white;
            padding: 20px;
            border-radius: 8px;
            width: 300px;
            text-align: center;
        }

        .modal-actions {
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
        }

        .modal-actions button {
            padding: 6px 12px;
            cursor: pointer;
        }

        .danger {
            background: #e53935;
            color: white;
            border: none;
        }
    </style>
</head>

<body>

    <div class="container">

        <header>
            <h1>URL Shortener</h1>
            <form action="/user/logout" method="get">
                <button class="logout-btn" type="submit">Logout</button>
            </form>
        </header>

        <% if (locals.id) { %>
            <div class="generated">
                URL Generated:
                <a href="http://localhost:8081/<%= id %>" target="_blank">
                    http://localhost:8081/<%= id %>
                </a>
            </div>
            <% } %>

                <!-- <form method="post" action="/url">
                    <label>
                        Enter Your Original URL
                        <input type="text" name="url" placeholder="https://example.com" required>
                    </label>
                    <br><br>
                    <button type="submit">Generate</button>
                </form> -->

                <form method="post" action="/url">
                    <label>
                        Enter Your Original URL
                        <input type="text" name="url" placeholder="https://example.com"
                            value="<%= oldInput ? oldInput.url : '' %>" required>
                    </label>

                    <% if (errors && errors.length> 0) { %>
                        <ul style="color:red">
                            <% errors.forEach(msg=> { %>
                                <li>
                                    <%= msg %>
                                </li>
                                <% }) %>
                        </ul>
                        <% } %>

                            <br><br>
                            <button type="submit">Generate</button>
                </form>

                <% if (locals.urls) { %>
                    <table>
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Short Id</th>
                                <th>Redirect URL</th>
                                <th>Clicks</th>
                                <th>Link</th>
                                <th>Action</th> <!-- New column -->
                            </tr>
                        </thead>
                        <tbody>
                            <% urls.forEach((url, index)=> { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= url.shortId %>
                                    </td>
                                    <td>
                                        <%= url.redirectURL %>
                                    </td>
                                    <td>
                                        <%= url.visitHistory.length %>
                                    </td>
                                    <td>
                                        <a href="http://localhost:8081/<%= url.shortId %>" target="_blank">Visit</a>
                                    </td>
                                    <td>
                                        <button onclick="openDeleteModal('<%= url.shortId %>')">Delete</button>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>
                        <div id="deleteModal" class="modal hidden">
                            <div class="modal-box">
                                <h3>Delete URL</h3>
                                <p>Are you sure you want to delete this URL?</p>

                                <div class="modal-actions">
                                    <button id="cancelDelete">Cancel</button>
                                    <button id="confirmDelete" class="danger">Delete</button>
                                </div>
                            </div>
                        </div>



    </div>


</body>

<script>
    let deleteTargetId = null;

    function openDeleteModal(shortId) {
        deleteTargetId = shortId;
        document.getElementById("deleteModal").classList.remove("hidden");
    }

    function closeDeleteModal() {
        deleteTargetId = null;
        document.getElementById("deleteModal").classList.add("hidden");
    }

    document.getElementById("cancelDelete").onclick = closeDeleteModal;

    document.getElementById("confirmDelete").onclick = async function () {
        if (!deleteTargetId) return;

        const res = await fetch(`/url/${deleteTargetId}`, {
            method: "DELETE",
        });

        if (res.ok) {
            closeDeleteModal();
            location.reload();
        } else {
            const data = await res.json();
            alert(data.error || "Failed to delete");
        }
    };
</script>




</html>