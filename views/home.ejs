<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Linkify</title>
    <link rel="stylesheet" href="/css/output.css">
    <!-- npx @tailwindcss/cli -i ./public/css/input.css -o ./public/css/output.css --watch -->
</head>

<body class="font-sans bg-gray-100 m-0 p-0">

    <div class="container max-w-4xl mx-auto bg-white p-6 rounded-lg shadow-lg my-10">

        <header class="flex justify-between items-center mb-6">
            <a href="/" class="no-underline">
                <h1 class="text-gray-800 text-2xl m-0">Linkify</h1>
            </a>
            <form action="/user/logout" method="get">
                <button type="submit"
                    class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded text-sm cursor-pointer">Logout</button>
            </form>
        </header>

        <% if (locals.id) { %>
            <div class="generated bg-blue-100 border-l-4 border-blue-500 p-3 mb-4">
                URL Generated:
                <a href="<%= baseUrl %>/<%= id %>" target="_blank" class="text-blue-600 underline">
                    <%= baseUrl %>/<%= id %>
                </a>
            </div>
            <% } %>

                <form method="post" action="/url" class="mb-5">
                    <label class="block">
                        Paste Your Long URL Here
                        <input type="text" name="url" placeholder="https://example.com/long-url"
                            value="<%= oldInput ? oldInput.url : '' %>"
                            class="w-full mt-2 p-2 border border-gray-300 rounded" required>
                    </label>

                    <% if (errors && errors.length> 0) { %>
                        <ul class="text-red-600 mt-2">
                            <% errors.forEach(msg=> { %>
                                <li>
                                    <%= msg %>
                                </li>
                                <% }) %>
                        </ul>
                        <% } %>

                            <button type="submit"
                                class="mt-4 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded cursor-pointer">Generate
                                Short Link</button>
                </form>


                <% if (locals.urls) { %>
                    <table class="w-full table-fixed border-collapse mt-5 text-sm ">
                        <thead class="rounded-lg">
                            <tr class="bg-gray-100 border border-gray-200 ">
                                <th class="w-12 px-3 py-4 text-left align-top font-semibold tracking-wide">S.No</th>
                                <th class="w-63 px-3 py-4 text-left align-top pl-9 font-semibold tracking-wide">Short
                                    Link</th>
                                <th class="w-6 px-3 py-4 align-top font-semibold tracking-wide"></th>
                                <th
                                    class="max-w-[450px] px-3 py-4 text-left align-top wrap-break-word pl-3 font-semibold tracking-wide">
                                    Redirect
                                    URL
                                </th>
                                <th class="w-20 px-3 py-4 text-center align-top font-semibold tracking-wide">Clicks</th>
                                <th class="w-16 px-3 py-4 text-left align-top font-semibold tracking-wide">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% urls.forEach((url, index)=> { %>
                                <tr class="border-b border-gray-300">
                                    <td class="px-3 py-4  align-top">
                                        <%= index + 1 %>
                                    </td>
                                    <td class="px-3 py-4 flex items-start gap-1 align-top ">
                                        <img src="/images/copy.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100 active:opacity-30"
                                            data-url="<%= baseUrl %>/<%= url.shortId %>" alt="Copy URL" />
                                        <a href="<%= baseUrl %>/<%= url.shortId %>" target="_blank"
                                            class="text-blue-600 no-underline wrap-break-word ">
                                            <%= baseUrl %>/<%= url.shortId %>
                                        </a>
                                    </td>
                                    <td class="px-3 py-4 text-gray-400 rotate-45 relative bottom-[4px]">↝</td>
                                    <td class="px-3 py-4  break-all whitespace-normal align-top max-w-[450px]">


                                        <div>
                                            <span class="redirectText line-clamp-2 break-all">
                                                <%= url.redirectURL %>
                                            </span>

                                            <button
                                                class="seeMore text-blue-600 text-xs ml-[1px] hidden hover:underline">
                                                see more
                                            </button>
                                        </div>

                                    </td>
                                    <td class="px-3 py-4 text-center align-top">
                                        <a class="text-blue-600 hover:underline" target="_blank"
                                            href="<%= baseUrl %>/url/analytics/<%= url.shortId %>">
                                            <%= url.visitHistory.length %>
                                        </a>
                                    </td>
                                    <td class="px-3 py-4 align-top flex gap-2">
                                        <img src="/images/edit.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100"
                                            alt="Edit URL" title="Edit"
                                            onclick="openEditModal('<%= url.shortId %>', '<%= url.redirectURL %>')" />
                                        <img src="/images/trash.svg"
                                            class="w-5 h-5 cursor-pointer opacity-70 transition-transform duration-150 ease-in-out hover:scale-110 hover:opacity-100"
                                            alt="Delete URL" title="Delete"
                                            onclick="openDeleteModal('<%= url.shortId %>')" />
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>

                        <!-- Edit Modal -->
                        <div id="editModal"
                            class="fixed inset-0 bg-opacity-40 flex items-center justify-center hidden z-50">
                            <div class="bg-white p-6 rounded-lg w-80 text-center border border-gray-500 shadow">
                                <h3 class="text-lg font-semibold mb-2">Edit URL</h3>
                                <p class="mb-3">Update the original URL:</p>
                                <input type="text" id="editUrlInput"
                                    class="w-full border border-gray-300 rounded p-2 mb-4"
                                    placeholder="Enter new URL" />

                                <div class="flex justify-between">
                                    <button id="cancelEdit"
                                        class="px-4 py-2 border rounded cursor-pointer">Cancel</button>
                                    <button id="confirmEdit"
                                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded cursor-pointer">Save</button>
                                </div>
                            </div>
                        </div>

                        <!-- Delete Modal -->
                        <div id="deleteModal"
                            class="fixed inset-0 bg-opacity-40 flex items-center justify-center hidden z-50">
                            <div class="bg-white p-6 rounded-lg w-80 text-center border border-gray-500 shadow">
                                <h3 class="text-lg font-semibold mb-2">Delete URL</h3>
                                <p class="mb-3">Are you sure you want to delete this URL?</p>

                                <div class="flex justify-between">
                                    <button id="cancelDelete"
                                        class="px-4 py-2 border rounded cursor-pointer">Cancel</button>
                                    <button id="confirmDelete"
                                        class="px-4 py-2 bg-red-500 hover:bg-red-600 active:bg-red-700 text-white rounded cursor-pointer">Delete</button>
                                </div>
                            </div>
                        </div>

    </div>

    <script>

        // Edit Function
        let editTargetId = null;

        function openEditModal(shortId, currentUrl) {
            editTargetId = shortId;
            document.getElementById("editUrlInput").value = currentUrl;
            document.getElementById("editModal").classList.remove("hidden");
        }

        function closeEditModal() {
            editTargetId = null;
            document.getElementById("editModal").classList.add("hidden");
        }

        document.getElementById("cancelEdit").onclick = closeEditModal;

        document.getElementById("confirmEdit").onclick = async function () {
            if (!editTargetId) return;

            const newUrl = document.getElementById("editUrlInput").value.trim();
            if (!newUrl) {
                alert("URL cannot be empty");
                return;
            }

            const res = await fetch(`/url/${editTargetId}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ newUrl }),
            });

            if (res.ok) {
                closeEditModal();
                location.reload();
            } else {
                const data = await res.json();
                alert(data.error || "Failed to update");
            }
        };

        // Delete Function
        let deleteTargetId = null;

        function openDeleteModal(shortId) {
            deleteTargetId = shortId;
            document.getElementById("deleteModal").classList.remove("hidden");
        }

        function closeDeleteModal() {
            deleteTargetId = null;
            document.getElementById("deleteModal").classList.add("hidden");
        }

        document.getElementById("cancelDelete").onclick = closeDeleteModal;

        document.getElementById("confirmDelete").onclick = async function () {
            if (!deleteTargetId) return;

            const res = await fetch(`/url/${deleteTargetId}`, {
                method: "DELETE",
            });

            if (res.ok) {
                closeDeleteModal();
                location.reload();
            } else {
                const data = await res.json();
                alert(data.error || "Failed to delete");
            }
        };

        // Copy Icon Function
        document.querySelectorAll(".copyIcon").forEach(icon => {
            icon.addEventListener("click", () => {
                const url = icon.dataset.url;

                navigator.clipboard.writeText(url)
                    .then(() => { })
                    .catch(err => {
                        console.error("Failed to copy: ", err);
                        alert("Failed to copy URL");
                    });
            });
        });

        // Redirect Text Function
        document.querySelectorAll(".redirectText").forEach(text => {
            const btn = text.nextElementSibling;

            if (text.scrollHeight > text.clientHeight) {
                btn.classList.remove("hidden");
            }

            btn.addEventListener("click", () => {
                text.classList.toggle("line-clamp-2");
                btn.innerText = btn.innerText === "see more" ? "see less" : "see more";
            });
        });


    </script>

</body>

</html>